generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  juicios   Juicio[]
  tareas    Tarea[]
}

model Juicio {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  tipo            String
  nro             String?
  autos           String
  estado          String
  fuero           String?
  juzgado         String?
  secretaria      String?
  sala            String?
  cosasRelevantes String?
  advertencia     String?
  driveUrl        String?
  iaUrl           String?
  datosJuzgado    String?
  datosContacto   String?
  otra