generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  juicios   Juicio[]
  tareas    Tarea[]
  asuntos   Asunto[]
  clientes  ClienteJuicio[]
}

model Juicio {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  tipo            String
  nro             String?
  autos           String
  estado          String
  fuero           String?
  juzgado         String?
  secretaria      String?
  sala            String?
  cosasRelevantes String?
  advertencia     String?
  driveUrl        String?
  iaUrl           String?
  pjnUrl          String?
  datosJuzgado    String?
  datosContacto   String?
  otraInfo        String?
  compartidoCon   String?
  categoria       String?
  createdAt       DateTime        @default(now())
  tareas          Tarea[]
  pruebas         Prueba[]
  honorarios      Honorario[]
  clientes        ClienteJuicio[]
}

model Tarea {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  juicioId  String?
  juicio    Juicio?   @relation(fields: [juicioId], references: [id])
  asuntoId  String?
  asunto    Asunto?   @relation(fields: [asuntoId], references: [id])
  texto     String
  fecha     DateTime?
  urgente   Boolean   @default(false)
  done      Boolean   @default(false)
  tipo      String?
  tema      String?
  info      String?
  webUrl    String?
  createdAt DateTime  @default(now())
}

model Prueba {
  id          String    @id @default(cuid())
  juicioId    String
  juicio      Juicio    @relation(fields: [juicioId], references: [id])
  tipo        String
  contenido   String?
  descripcion String?
  detalle     String?
  estado      String    @default("Ofrecida")
  vencimiento DateTime?
  createdAt   DateTime  @default(now())
}

model Honorario {
  id                 String   @id @default(cuid())
  juicioId           String
  juicio             Juicio   @relation(fields: [juicioId], references: [id])
  clienteContraparte String?
  total              String?
  pagado             String?
  estado             String   @default("Pendiente")
  observaciones      String?
  createdAt          DateTime @default(now())
}

model Asunto {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  nombre      String
  tipo        String
  estado      String   @default("Abierta")
  advertencia String?
  otraInfo    String?
  driveUrl    String?
  webUrl      String?
  createdAt   DateTime @default(now())
  tareas      Tarea[]
}

model ClienteJuicio {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  juicioId  String
  juicio    Juicio   @relation(fields: [juicioId], references: [id], onDelete: Cascade)
  apellido  String
  nombre    String
  dni       String?
  correo    String?
  telefono  String?
  domicilio String?
  createdAt DateTime @default(now())
}
